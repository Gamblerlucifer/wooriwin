# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Google Service Account Key (절대 커밋 금지)
/keys/

# 로컬 운영 데이터 (커밋 불필요)
/data/backlinks/
/data/disavow/
wooriwin-indexing.json
service_account.json
*-indexing.json
*.serviceaccount.json

# zip/tar (실수 방지)
*.zip
*.tar.gz

# 주의: /data/posts/ 는 GitHub에 커밋되어야 빌드 시 사이트맵에 포함됨
# 로컬 테스트 시 생성된 파일은 git status에서 확인 후 선별 커밋

# 자동 생성 파이프라인의 색인 알림용 임시 파일 (커밋 불필요)
/data/.new-posts-pending.json

# GSC 색인 요청 진행 상태 로컬 추적 파일 (커밋 불필요)
/data/.gsc-checklist-done.json

# next-sitemap 빌드 시 자동 생성 (커밋 불필요)
/public/sitemap.xml
/public/sitemap-*.xml
/public/robots.txt

# Python bytecode cache
__pycache__/
*.pyc
