# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Google Service Account Key (절대 커밋 금지)
wooriwin-indexing.json
service_account.json
*-indexing.json
*.serviceaccount.json

# zip/tar (실수 방지)
*.zip
*.tar.gz

# 주의: /data/posts/ 는 GitHub에 커밋되어야 빌드 시 사이트맵에 포함됨
# 로컬 테스트 시 생성된 파일은 git status에서 확인 후 선별 커밋
